{
  "name": "moroshko.me",
  "version": "2.0.0",
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "check": "biome check --write --error-on-warnings",
    "ci": "next typegen && bun tsc && biome ci --error-on-warnings",
    "env": "vercel env pull .env.local"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "clsx": "2.1.1",
    "geist": "1.7.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vercel": "^50.32.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "lefthook": "2.1.4",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "license": "MIT"
}
